# Supabase — shared with Ava Health CRM project
NEXT_PUBLIC_SUPABASE_URL=https://tsruqbodyrmxqzhvxret.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<set-from-supabase-dashboard-api-keys>

# Cloudflare Turnstile (anti-spam on post-job form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<set-when-turnstile-widget-created>
TURNSTILE_SECRET_KEY=<server-side-only>

# App base URL (used in email verify links)
NEXT_PUBLIC_APP_URL=https://freejobpost.co

# Shared invoke secret for Supabase edge functions.
# Set the same value in each edge function's Supabase Secrets (Dashboard → Edge Functions → Secrets)
# and add an X-Invoke-Secret header check in each function before it processes requests.
# This prevents anon-key holders from calling edge functions directly to spam emails.
# EDGE_FUNCTION_INVOKE_SECRET=<generate-with-openssl-rand-base64-32>

# Supabase service role key — REQUIRED for /admin/* pages (server-side only,
# bypasses RLS for the partner-attribution dashboard read on
# partner_attribution_daily view). NEVER ship this to the browser. Set in
# Vercel project settings as a non-public env var.
# SUPABASE_SERVICE_ROLE_KEY=<set-from-supabase-dashboard-api-keys>

# Shared secret for /admin/* page access. Used as `?key=<value>` query param
# on the admin URL. /admin/attribution returns 404 unless the URL key matches
# this env var. Generate once with `openssl rand -hex 24` and bookmark the
# full URL including the key. Rotate by updating both .env.local and Vercel.
# ADMIN_DASHBOARD_KEY=<generate-with-openssl-rand-hex-24>
